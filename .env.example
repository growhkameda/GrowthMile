# 環境変数テンプレート — コピーして .env を作成する（.env は git 管理外）
#   cp .env.example .env
# 実値をこのファイルに書かないこと（テンプレートのみ）。

# PostgreSQL 接続文字列（docker compose up -d db のローカル DB に合わせた例）
DATABASE_URL="postgresql://user:password@localhost:5432/growth_mile_db"

# Auth.js v5 のセッション署名シークレット（32文字以上）
# 生成例: openssl rand -base64 32
AUTH_SECRET=""

# 任意: 明示したい場合のみ設定（Vercel 等では自動解決されるため通常は不要）
# AUTH_URL="http://localhost:3000"
